{
  "name": "SDR Gatekeeper - Expiração de Conversas",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 */30 8-18 * * *"
            }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "Cron - 30min (8h-18h30 BRT)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        250,
        600
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Branch 1: Detecta Stalled (2h sem resposta)\n-- Transição: greeting_sent | gathering_decisor → stalled\n-- Teto de 24h: conversas com > 24h pertencem ao Branch 2 (expired)\nUPDATE gk_conversations\nSET status = 'stalled',\n    updated_at = NOW()\nWHERE status IN ('greeting_sent', 'gathering_decisor')\n  AND last_message_at < NOW() - INTERVAL '2 hours'\n  AND last_message_at >= NOW() - INTERVAL '24 hours'\n  AND paused IS NOT TRUE\nRETURNING id, remote_jid, push_name, last_message_at;",
        "options": {}
      },
      "id": "detect-stalled",
      "name": "Supabase - Detecta Stalled",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        480,
        200
      ],
      "credentials": {
        "postgres": {
          "id": "SUPABASE_CREDENTIALS_ID",
          "name": "Postgres SDR Gatekeeper"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-stalled-id",
              "leftValue": "={{ $json.id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "filter-stalled",
      "name": "Filtro - Tem Stalled?",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [
        730,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE gk_leads l\nSET status = 'stalled', updated_at = NOW()\nFROM gk_conversations c\nWHERE l.conversation_id = '{{ $json.id }}'\n  AND l.conversation_id = c.id\n  AND l.status NOT IN ('decisor_captured', 'opted_out', 'closed', 'failed')\nRETURNING c.id, c.remote_jid, c.last_message_at, c.push_name;",
        "options": {}
      },
      "id": "update-lead-stalled",
      "name": "Supabase - Lead Stalled",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        980,
        200
      ],
      "credentials": {
        "postgres": {
          "id": "SUPABASE_CREDENTIALS_ID",
          "name": "Postgres SDR Gatekeeper"
        }
      },
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO gk_messages (conversation_id, direction, content, message_type, stage)\nVALUES (\n  '{{ $json.id }}',\n  'outbound',\n  'Oi! Tudo bem? Estava esperando sua resposta para continuar. Pode me ajudar? 😊',\n  'text',\n  'stalled'\n);",
        "options": {}
      },
      "id": "save-nudge-1",
      "name": "Supabase - Salva Nudge 1",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1230,
        200
