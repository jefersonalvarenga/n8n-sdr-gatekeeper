    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.EVOLUTION_API_URL }}/message/sendText/{{ $env.EVOLUTION_INSTANCE_NAME }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.EVOLUTION_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": {{ $('Supabase - Lê Config').first().json.environment === 'homolog' ? JSON.stringify(($('Supabase - Lê Config').first().json.homolog_phone || '').replace(/\\D/g,'')) : JSON.stringify($json.remote_jid) }},\n  \"text\": \"Oi! Tudo bem? Estava esperando sua resposta para continuar. Pode me ajudar? 😊\"\n}",
        "options": {
          "timeout": 15000
        }
      },
      "id": "send-nudge-1",
      "name": "Evolution - Envia Nudge 1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
